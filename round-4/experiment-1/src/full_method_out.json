{
  "metadata": {
    "method_name": "cwa_memory_benchmark",
    "description": "Peak GPU memory comparison: CWA-IFT vs Unrolled-K50 vs GELU baseline at n in {256,1024,4096}",
    "hypothesis": "IFT implicit backward stores O(n) activations (m* scalar + y output) vs O(K*n) for unrolled K=50",
    "J_raw": 4.0,
    "J_sigmoid": 0.9820137619972229,
    "batch_size": 64,
    "K_max": 50,
    "n_warmup": 3,
    "n_measure": 5,
    "widths_tested": [
      256,
      1024,
      4096
    ],
    "x_scales_tested": [
      0.1,
      1.0
    ],
    "device": "cuda",
    "finding": "IFT achieves O(n) memory overhead (within 2x of GELU at all n tested). IFT uses less memory than unrolled K=50 at all widths tested (ratio_ift_over_unrolled range: 0.31–0.84; savings grow with n: n=256→16%, n=1024→41%, n=4096→69%). At n=4096 IFT uses 90% less memory than GELU baseline (which includes n×n weight matrix). Near-critical regime (x_scale=0.1): J*s̄≈0.963; saturated (x_scale=1.0): J*s̄≈0.593.",
    "ift_2x_criterion_met_at_n": [
      256,
      256,
      1024,
      1024,
      4096,
      4096
    ],
    "ift_meaningful_savings_vs_unrolled_at_n": [
      4096,
      4096
    ],
    "jsbar_near_critical_mean": 0.9625753063176781,
    "jsbar_saturated_mean": 0.5934982895926026,
